# Somnia Shannon testnet (see docs/somnia-reactivity-docs/network-info/network-config.md)

SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_WS_URL=ws://api.infra.testnet.somnia.network/ws

# Deployed WorkflowRegistry on Shannon (see root README table)
WORKFLOW_REGISTRY_ADDRESS=0x231658eDc3CF6a3CeEADf6657A1A01Fa3bC942eC
# Optional reference: AuditLog from the same deploy batch
# AUDIT_LOG_ADDRESS=0x41ffe131489F874B1759a2EeF5C9795AF4C9d50A

# 64 hex chars, with or without 0x (quotes optional). Needs STT for gas + 32+ STT for reactivity subscribe.
PRIVATE_KEY=

# Shannon RPC often underestimates CREATE gas — use for `forge create` + backend MeshWorkflowExecutor deploys
MESH_CONTRACT_DEPLOY_GAS=30000000

# Pinned demo emitter (Ping) — set so `/demo` + POST /chain/ping match bootstrap workflows without redeploying emitter
DEMO_TRIGGER_EMITTER=0x268c2bE29D6b4e062ff979dA62931EEFF49FA1af

# Optional gas overrides for createSoliditySubscription (defaults match Somnia gas docs)
# MESH_PRIORITY_FEE_GWEI=2
# MESH_MAX_FEE_GWEI=10
# MESH_SUBSCRIPTION_GAS_LIMIT=2000000

# Override only if artifacts live outside backend/contracts (default: backend/contracts/out)
# CONTRACTS_ROOT=/path/to/custom/contracts

# Demo: live trace + hybrid evaluation WebSockets
TRACE_ENGINE=1
EVALUATION_ENGINE=1

# Optional: Bearer token for admin routes (set on Render to run bootstrap remotely):
#   POST /admin/evaluation/sync — reload hybrid subscriptions from index
#   POST /admin/shannon-demo-bootstrap — same as npm run demo:bootstrap:shannon (fills workflows-index on this server)
# MESH_ADMIN_TOKEN=

# Allow evaluation onPass hooks of type rawTx (dangerous — uses PRIVATE_KEY)
# MESH_ALLOW_EVAL_RAW_TX=1

PORT=8787

# CORS: comma-separated origins, or omit for allow-all (see server.ts)
FRONTEND_ORIGIN=http://localhost:3000
