# Somnia Shannon testnet (see docs/somnia-reactivity-docs/network-info/network-config.md)

SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_WS_URL=ws://api.infra.testnet.somnia.network/ws

WORKFLOW_REGISTRY_ADDRESS=
# 64 hex chars, with or without 0x (quotes optional). Needs STT for gas + 32+ STT for reactivity subscribe.
PRIVATE_KEY=

# Optional gas overrides for createSoliditySubscription (defaults match Somnia gas docs)
# MESH_PRIORITY_FEE_GWEI=2
# MESH_MAX_FEE_GWEI=10
# MESH_SUBSCRIPTION_GAS_LIMIT=2000000

# If backend cannot find ../contracts/out (monorepo), set absolute path to contracts dir
# CONTRACTS_ROOT=/path/to/mesh-somnia/contracts

# Set to 1 to log every wildcard reactivity push to stdout
# TRACE_ENGINE=1

# Set to 1 to start per-workflow sdk.subscribe pushes with root ethCalls + off-chain condition (see docs/evaluation-engine.md)
# EVALUATION_ENGINE=1

# Optional: Bearer token for POST /admin/evaluation/sync (reload hybrid subscriptions from index)
# MESH_ADMIN_TOKEN=

# Allow evaluation onPass hooks of type rawTx (dangerous — uses PRIVATE_KEY)
# MESH_ALLOW_EVAL_RAW_TX=1

PORT=8787

# CORS: comma-separated origins, or omit / use * pattern via FRONTEND_ORIGIN=* in code (see server.ts)
# FRONTEND_ORIGIN=http://localhost:3000
